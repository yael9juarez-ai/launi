rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UNI EATS SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset enforces a multi-tiered authorization model for the UniEats cafeteria system. 
     * It distinguishes between Customers (Students, Professors, Admin-Clients) and Staff 
     * (Cashier, Kitchen, Admin-Staff) using existence-based role checks.
     *
     * Data Structure:
     * - Top-level collections are used for global data (Categories, MenuItems) and shared 
     *   transactional data (Orders, Ratings).
     * - Access to shared documents is secured via denormalized identity fields (e.g., userId).
     * - High-privilege role verification is handled via dedicated role-lookup collections.
     *
     * Key Security Decisions:
     * - PUBLIC READ: Categories and Menu Items are public to allow menu browsing without login.
     * - ROLE-BASED ACCESS (DBAC): Roles like 'admin-staff', 'kitchen', and 'cashier' are 
     *   verified by checking for the existence of a document in specific role-collections.
     * - OWNERSHIP: Orders and Ratings are secured by verifying the `userId` field within 
     *   the document matches the requester's UID.
     * - PROTOTYPING FLEXIBILITY: Schema validation is omitted to allow rapid development, 
     *   except for critical relational fields (e.g., ensuring a user creates data for themselves).
     *
     * Denormalization for Authorization:
     * To ensure high performance and avoid deep nesting or costly 'get()' calls, the `userId` 
     * of the owner is denormalized into Orders, OrderItems, and Ratings.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Role-based existence checks (DBAC Pattern)
    function isAdminStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_adminStaff/$(request.auth.uid));
    }

    function isCashier() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_cashier/$(request.auth.uid));
    }

    function isKitchen() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_kitchen/$(request.auth.uid));
    }

    function isStaff() {
      return isAdminStaff() || isCashier() || isKitchen();
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User profile collection. Users manage their own profiles; admins see all.
     * @path /users/{userId}
     * @allow (get) If user is the owner or an admin-staff.
     * @deny (create) If the ID in data does not match the auth UID.
     * @principle Ownership for personal data; Administrative override for staff.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdminStaff();
      allow list: if isAdminStaff();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdminStaff()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdminStaff();
    }

    /**
     * @description Security for role-assignment collections. Strictly restricted to admin-staff.
     * @path /roles_.../{userId}
     * @allow (get) Any signed-in user can check their own role.
     * @deny (write) Any non-admin user attempting to change roles.
     * @principle Restricted administrative control for system roles.
     */
    match /roles_adminStaff/{userId} {
      allow get: if isOwner(userId) || isAdminStaff();
      allow list, create, update, delete: if isAdminStaff();
    }
    match /roles_cashier/{userId} {
      allow get: if isOwner(userId) || isAdminStaff();
      allow list, create, update, delete: if isAdminStaff();
    }
    match /roles_kitchen/{userId} {
      allow get: if isOwner(userId) || isAdminStaff();
      allow list, create, update, delete: if isAdminStaff();
    }
    match /roles_adminClient/{userId} {
      allow get: if isOwner(userId) || isAdminStaff();
      allow list, create, update, delete: if isAdminStaff();
    }

    /**
     * @description Publicly readable menu categories. Modified only by admins.
     * @path /categories/{categoryId}
     * @allow (list) Publicly accessible.
     * @deny (create) Non-admin attempts to modify categories.
     * @principle Public read with owner-only (admin) writes.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdminStaff();
    }

    /**
     * @description Publicly readable menu items. Modified only by admins.
     * @path /menuItems/{menuItemId}
     * @allow (get) Publicly accessible.
     * @deny (delete) Unauthorized user attempting to remove menu items.
     * @principle Public read with owner-only (admin) writes.
     */
    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdminStaff();
    }

    /**
     * @description Orders collection. Secured via denormalized 'userId'.
     * @path /orders/{orderId}
     * @allow (create) Signed-in user setting themselves as the owner.
     * @deny (list) User attempting to see orders that are not theirs.
     * @principle Ownership-based filtering for clients; role-based access for staff.
     */
    match /orders/{orderId} {
      allow get: if isOwner(resource.data.userId) || isStaff();
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 100); // Clients must filter by userId in queries
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.userId) || isStaff()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdminStaff();

      /**
       * @description Order items subcollection. Inherits parent order ownership via denormalized field.
       * @path /orders/{orderId}/orderItems/{orderItemId}
       * @principle Denormalized owner ID prevents expensive parent lookups.
       */
      match /orderItems/{orderItemId} {
        allow get, list: if isOwner(resource.data.userId) || isStaff();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if (isExistingOwner(resource.data.userId) || isStaff()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isAdminStaff();
      }
    }

    /**
     * @description Inventory management. Restricted to Kitchen and Admin staff.
     * @path /inventoryItems/{inventoryItemId}
     * @allow (get) Staff viewing stock levels.
     * @deny (write) Non-staff users.
     * @principle Staff-only data access.
     */
    match /inventoryItems/{inventoryItemId} {
      allow get, list, create, update, delete: if isKitchen() || isAdminStaff();

      /**
       * @description Audit trail for inventory. Read-only once created.
       * @path /inventoryItems/{inventoryItemId}/transactions/{transactionId}
       */
      match /transactions/{transactionId} {
        allow get, list, create: if isKitchen() || isAdminStaff();
        allow update, delete: if false; 
      }
    }

    /**
     * @description Customer feedback and ratings.
     * @path /ratings/{ratingId}
     * @allow (list) Publicly readable.
     * @deny (update) User attempting to edit someone else's comment.
     * @principle Public read with owner-only writes.
     */
    match /ratings/{ratingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId) || isAdminStaff();
    }
  }
}