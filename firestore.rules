rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isCashier() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_cashier/$(request.auth.uid));
    }

    function isKitchen() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_kitchenstaff/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isCashier() || isKitchen();
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    match /{role_collection}/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /reviews/{reviewId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isExistingOwner(resource.data.userId);
      }

      match /recipeItems/{recipeItemId} {
        // Los alumnos necesitan ver recetas para cálculos de disponibilidad en el cliente
        allow get, list: if isSignedIn(); 
        allow create, update, delete: if isKitchen() || isAdmin();
      }
    }

    match /ingredients/{ingredientId} {
      // Los alumnos necesitan ver el stock actual para saber si un producto está disponible
      allow get, list: if isSignedIn();
      allow create, update, delete: if isKitchen() || isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isOwner(resource.data.userId) || isStaff();
      // Permitir listar pedidos si el usuario está autenticado (Monitor de turnos y Alumnos)
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.userId) || isStaff()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();

      match /orderItems/{orderItemId} {
        allow get, list: if isOwner(resource.data.userId) || isStaff();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if (isExistingOwner(resource.data.userId) || isStaff()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isAdmin();
      }
    }
  }
}