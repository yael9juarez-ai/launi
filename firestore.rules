rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Un usuario es Admin si existe en la colección de roles o tiene el campo role en su perfil
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Un usuario es Cocinero si existe en la colección de roles o tiene el campo role en su perfil
    function isKitchen() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_kitchenstaff/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "cocinero"
      );
    }

    function isStaff() {
      return isAdmin() || isKitchen();
    }

    // --- Reglas de Colecciones ---

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /ingredients/{ingredientId} {
      // Todos los alumnos necesitan ver los ingredientes para saber si hay stock
      allow read: if isSignedIn();
      // Solo el staff puede ajustar el inventario
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      // Todos los usuarios autenticados pueden ver órdenes (alumnos las suyas, staff todas)
      allow read: if isSignedIn();
      // Cualquier alumno puede crear órdenes
      allow create: if isSignedIn();
      // El staff actualiza estados, el alumno puede actualizar su propia orden (ej. confirmar pago)
      allow update: if isSignedIn();
      // Solo admins pueden borrar registros históricos
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menuItems/{menuItemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Roles (DBAC - Database Access Control)
    // Se permite lectura y escritura propia al loguearse para inicializar el perfil
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && userId == request.auth.uid;
    }
    
    match /roles_kitchenstaff/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && userId == request.auth.uid;
    }

    match /roles_cashier/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}