rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UNI-EATS SECURITY RULES (PROTOTYPING MODE)
     *
     * Core Philosophy:
     * This ruleset enforces a strict role-based and ownership-based security model. 
     * It uses dedicated collections (DBAC) to store user roles, allowing for performant 
     * security checks without slow document lookups on the main user profile.
     *
     * Data Structure:
     * - User-specific data is nested under /users/{userId}.
     * - Order data is denormalized across three paths to satisfy different access patterns:
     *   1. /users/{userId}/orders: Private history for the customer.
     *   2. /kitchen_orders: Operational queue for staff.
     *   3. /public_queue: Minimal, anonymous view for the order status screen.
     * - Menu content (categories, items) is publicly readable but restricted to admin for management.
     *
     * Key Security Decisions:
     * - Role-Based Access Control (RBAC): Uses 'exists()' checks against /roles_admin, 
     *   /roles_kitchen_staff, and /roles_cashier for instant authorization.
     * - Ownership: Customers can only see their own order history.
     * - Public Display: The /public_queue is world-readable but contains no sensitive user data.
     * - Prototyping Flexibility: Rules do not enforce exact schema types for content fields 
     *   (like 'description' or 'price') to allow for rapid UI/UX iterations, but they 
     *   STRICTLY enforce ownership IDs and relational consistency.
     *
     * Denormalization for Authorization:
     * - Orders and Reviews contain a denormalized 'userId' or 'authorId' to avoid checking parent docs.
     * - Kitchen-specific views contain only the data necessary for preparation to simplify queries (QAP).
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isKitchenStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_kitchen_staff/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isKitchenStaff() || exists(/databases/$(database)/documents/roles_cashier/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Access control markers for Admin role.
     * @path /roles_admin/{userId}
     * @allow (get) Any signed-in user checking their own role status.
     * @deny (write) Any non-admin user attempting to grant themselves privileges.
     * @principle Role-Based Access Control (DBAC).
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Access control markers for Kitchen Staff role.
     * @path /roles_kitchen_staff/{userId}
     * @allow (get) Signed-in staff checking permissions.
     * @deny (create) Non-admin users.
     * @principle Role-Based Access Control (DBAC).
     */
    match /roles_kitchen_staff/{userId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description User profile management.
     * @path /users/{userId}
     * @allow (create) New users setting up their own profile.
     * @deny (update) Changing the document ID or modifying another user's profile.
     * @principle Self-Creation and Path-Based Ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Publicly readable menu organization.
     * @path /categories/{categoryId}
     * @allow (list) All users browsing the menu categories.
     * @deny (update) Staff or clients trying to rename categories.
     * @principle Public Read with Admin-Only Writes.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Publicly readable cafeteria items.
     * @path /menu_items/{menuItemId}
     * @allow (get) Customers viewing item details.
     * @deny (create) Non-admin users adding items.
     * @principle Public Read with Admin-Only Writes.
     */
    match /menu_items/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Back-of-house inventory and recipe management.
     * @path /ingredients/{ingredientId}, /inventory/{inventoryId}, /recipe_ingredients/{recipeIngredientId}
     * @allow (get, list, write) Admins and Kitchen Staff managing stock.
     * @deny (get) Regular clients browsing technical inventory data.
     * @principle Structural Segregation for staff operations.
     */
    match /ingredients/{ingredientId} {
      allow get, list, create, update, delete: if isStaff();
    }
    match /inventory/{inventoryId} {
      allow get, list, create, update, delete: if isStaff();
    }
    match /recipe_ingredients/{recipeIngredientId} {
      allow get, list, create, update, delete: if isStaff();
    }

    /**
     * @description Private order history for clients.
     * @path /users/{userId}/orders/{orderId}
     * @allow (create) User placing a new order for themselves.
     * @deny (list) User attempting to see orders belonging to another UID.
     * @principle Path-based ownership with relational integrity.
     */
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if (isExistingOwner(userId) && request.resource.data.userId == resource.data.userId) || isAdmin();
      allow delete: if isAdmin();

      match /order_items/{orderItemId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Operational queue for kitchen preparation.
     * @path /kitchen_orders/{orderId}
     * @allow (update) Kitchen staff marking an order as 'preparing' or 'ready'.
     * @deny (list) Regular customers accessing the full kitchen workflow.
     * @principle Specialized staff-only view (QAP).
     */
    match /kitchen_orders/{orderId} {
      allow get, list, create, update, delete: if isStaff();
    }

    /**
     * @description Anonymous public display for order tracking.
     * @path /public_queue/{orderId}
     * @allow (get, list) All users (including anonymous display screens).
     * @deny (write) Any non-staff user attempting to modify queue positions.
     * @principle World Read for public utility data.
     */
    match /public_queue/{orderId} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    /**
     * @description Customer feedback and ratings.
     * @path /reviews/{reviewId}
     * @allow (create) Authenticated user submitting their own review.
     * @deny (update) User trying to edit someone else's review.
     * @principle Public Read with Owner-Only Writes.
     */
    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.userId) || isAdmin();
    }
  }
}