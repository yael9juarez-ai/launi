rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de ayuda
    function isSignedIn() {
      return request.auth != null;
    }

    // Permitir a cualquier usuario autenticado leer y escribir en su propio perfil
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // Reglas para pedidos: alumnos, monitor y personal necesitan leer/escribir
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // Reglas para ingredientes: lectura pública, actualización por usuarios logueados (descuento de stock)
    match /ingredients/{ingredientId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Reglas para reseñas: lectura pública, creación por alumnos
    match /service_reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    
    // Reglas para roles
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn();
    }
    
    match /roles_kitchenstaff/{userId} {
      allow read, write: if isSignedIn();
    }
  }
}